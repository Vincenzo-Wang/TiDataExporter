# Local Docker development only.
# Production deployment should use deploy/env/*.env.example with Jenkins + systemd + Nginx.

# Server runtime
SERVER_MODE=debug

# Database
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=claw_export
MYSQL_USER=claw
MYSQL_PASSWORD=claw123
MYSQL_PORT=3306

# Redis
REDIS_PASSWORD=redis123
REDIS_PORT=6379

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
AES_KEY=0123456789abcdef0123456789abcdef

# Published ports (Docker host)
FRONTEND_PORT=80
BACKEND_PORT=8080

# Worker
WORKER_COUNT=4

# S3 Configuration (optional - for default storage)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=

# Logging
LOG_LEVEL=info

# Dumpling on host (mounted into backend and worker container)
HOST_DUMPLING_PATH=/usr/local/bin/dumpling
