# Application
APP_ENV=development
APP_PORT=8080

# Database
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=claw_export
MYSQL_USER=claw
MYSQL_PASSWORD=claw123
MYSQL_PORT=3306

# Redis
REDIS_PASSWORD=redis123
REDIS_PORT=6379

# Security - CHANGE THESE IN PRODUCTION!
